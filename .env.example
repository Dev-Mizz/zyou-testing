# Client (browser) — the ONLY value the frontend needs. It's just your project
# URL, not a key. Zero Supabase keys ship to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# WhatsApp community link shown on the page (WhatsAppRow). Client value → needs VITE_ prefix.
VITE_WHATSAPP_URL=https://chat.whatsapp.com/xxxx

# Cloudflare Turnstile site key — public, safe in the browser.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAr4uyferhgdjwksnhjsv

# ─────────────────────────────────────────────────────────────────────────
# Everything below is a SERVER secret. It lives in the Edge Function's env via
#   supabase secrets set NAME=value
# NEVER put these in .env / VITE_* — that would ship them to the browser.
#   GMAIL_USER=you@gmail.com                # the Gmail account that sends
#   GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx      # Google App Password (16 chars, needs 2FA on) — NOT your login password
#   TEAM_EMAIL=founders@zyou.ai            # where new-lead notifications go
#   FROM_EMAIL=Zyou <you@gmail.com>         # optional; Gmail forces the address to GMAIL_USER
#   ALLOWED_ORIGIN=https://zyou.ai,http://localhost:5173
#   WHATSAPP_URL=https://chat.whatsapp.com/xxxx   # community link in the welcome email
#   LOGO_URL=https://zyou.ai/logos/Logo_Dark.svg  # email logo (defaulted). SVG won't show in Gmail/Outlook —
#                                                 # use public/logos/lockup-email.png for all-client support.
#   TURNSTILE_SECRET_KEY=0x4AAAAAAA...      # only if you add Turnstile
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected into functions.)
